DATABASE_URL="mysql://user:pass@host:3306/clinicdb?ssl-mode=REQUIRED"
# Railway MySQL alternative:
# MYSQL_URL="mysql://user:pass@host:3306/clinicdb?ssl-mode=REQUIRED"
DJANGO_SECRET_KEY="change-me"
DJANGO_DEBUG="1"
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"
FRONTEND_ORIGIN="http://localhost:3000,https://your-vercel-app.vercel.app"
JWT_SECRET="change-me"
JWT_EXPIRES_MINUTES="1440"
ADMIN_PASSWORD_RESET_TOKEN_TTL_MINUTES="60"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
MAX_VIDEO_MB="100"
# For Railway, prefer a mounted volume path such as /data/media
MEDIA_ROOT="./media"
VIDEOS_DIR="./media/videos"
GUNICORN_WORKERS="3"
GUNICORN_TIMEOUT="120"
